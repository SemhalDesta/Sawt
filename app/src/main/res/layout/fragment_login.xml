<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginFragment"
    android:background="#0D0D0D"
    android:padding="50dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_signin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView
                android:id="@+id/tab_signin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sign in"
                android:textColor="#FFFFFF"
                android:textSize="17dp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="10dp"
                />
            <TextView
                android:id="@+id/tab_register"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Register"
                android:textColor="#6D6D6D"
                android:textSize="17dp"
                android:gravity="center"
                android:paddingBottom="10dp"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp"
            >
            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/outline_multimodal_hand_eye_24"
                android:layout_gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAWT"
                android:textColor="#FFFFFF"
                android:textSize="24dp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="voice through sight"
                android:textColor="#A4A3A3"
                android:textSize="15dp"
                android:layout_gravity="center"
                android:layout_marginTop="7dp" />
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#979696"
                android:layout_marginTop="7dp"
                />
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#A4A3A3"
            android:textSize="15dp"
            android:layout_marginBottom="6dp"
            />
        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:hint="name@email.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#A4A3A3"
            android:textSize="15dp"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/input_background"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:endIconMode="password_toggle"
            app:endIconTint="#A4A3A3">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="14dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:gravity="center_vertical"
                android:textColor="#FFFFFF"
                android:textColorHint="#444444"
                android:hint="********"
                android:inputType="textPassword"/>
        </com.google.android.material.textfield.TextInputLayout>
        <Button
            style="@style/AppButton"
            android:id="@+id/btn_main"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Sign in"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No account? "
                android:textColor="#A4A3A3"
                android:textSize="15dp"/>

            <TextView
                android:id="@+id/tv_switch_register"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register here"
                android:textColor="#FFFFFF"
                android:textSize="15dp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_register"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="invisible"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView
                android:id="@+id/tab_signin_register"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sign in"
                android:textColor="#6D6D6D"
                android:textSize="17dp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="10dp"
                />
            <TextView
                android:id="@+id/tab_register_register"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Register"
                android:textColor="#FFFFFF"
                android:textSize="17dp"
                android:gravity="center"
                android:paddingBottom="10dp"/>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full name"
            android:textColor="#6D6D6D"
            android:textSize="12dp"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:inputType="textPersonName"
            android:layout_marginBottom="16dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone number"
            android:textColor="#6D6D6D"
            android:textSize="12dp"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/et_phone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:hint="+971 ** *** ****"
            android:inputType="phone"
            android:layout_marginBottom="16dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#6D6D6D"
            android:textSize="15dp"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/et_email_register"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:hint="example@email.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#6D6D6D"
            android:textSize="15dp"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/input_background"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:endIconMode="password_toggle"
            app:endIconTint="#A4A3A3">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password_register"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="14dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:gravity="center_vertical"
                android:textColor="#FFFFFF"
                android:textColorHint="#444444"
                android:hint="********"
                android:inputType="textPassword"/>
        </com.google.android.material.textfield.TextInputLayout>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Who are you registering as?"
            android:layout_marginBottom="10dp"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <Button
                style="@style/AppButton"
                android:id="@+id/btn_patient"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Patient"
                android:layout_marginEnd="10dp"/>
            <Button
                style="@style/AppButton"
                android:id="@+id/btn_caregiver"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Care Giver"/>

        </LinearLayout>
        <LinearLayout
            android:id="@+id/layout_patient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="invisible"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Caregiver's Phone number"
                android:textColor="#6D6D6D"
                android:textSize="15dp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/et_phone_caregiver"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#444444"
                android:hint="+971 ** *** ****"
                android:inputType="phone"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
        <Button
            style="@style/AppButton"
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Register"
            android:layout_margin="16dp"/>

    </LinearLayout>
</FrameLayout>